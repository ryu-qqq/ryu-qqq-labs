{
  "annotations": { "list": [] },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "links": [],
  "panels": [
    {
      "title": "Heap Memory Used (MB)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": { "defaults": { "unit": "decmbytes" }, "overrides": [] },
      "targets": [
        { "expr": "jvm_memory_used_bytes{area=\"heap\"} / 1024 / 1024", "legendFormat": "{{id}}" }
      ]
    },
    {
      "title": "Heap Max vs Used (MB)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": { "defaults": { "unit": "decmbytes" }, "overrides": [] },
      "targets": [
        { "expr": "jvm_memory_used_bytes{area=\"heap\"} / 1024 / 1024", "legendFormat": "used ({{id}})" },
        { "expr": "jvm_memory_max_bytes{area=\"heap\"} / 1024 / 1024", "legendFormat": "max ({{id}})" }
      ]
    },
    {
      "title": "GC Pause Time (ms)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": { "defaults": { "unit": "ms" }, "overrides": [] },
      "targets": [
        { "expr": "rate(jvm_gc_pause_seconds_sum[30s]) / rate(jvm_gc_pause_seconds_count[30s]) * 1000", "legendFormat": "avg {{action}} - {{cause}}" },
        { "expr": "jvm_gc_pause_seconds_max * 1000", "legendFormat": "max {{action}} - {{cause}}" }
      ]
    },
    {
      "title": "GC Pause Count (per sec)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        { "expr": "rate(jvm_gc_pause_seconds_count[30s])", "legendFormat": "{{action}} - {{cause}}" }
      ]
    },
    {
      "title": "GC Total Pause (ms/sec)",
      "description": "1초당 GC에 소비된 총 시간. 높을수록 애플리케이션이 멈춘 시간이 많다.",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 16 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": { "defaults": { "unit": "ms" }, "overrides": [] },
      "targets": [
        { "expr": "rate(jvm_gc_pause_seconds_sum[30s]) * 1000", "legendFormat": "{{action}} - {{cause}}" }
      ]
    },
    {
      "title": "CPU Usage (%)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 16 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": { "defaults": { "unit": "percent", "min": 0, "max": 100 }, "overrides": [] },
      "targets": [
        { "expr": "process_cpu_usage * 100", "legendFormat": "JVM process CPU" },
        { "expr": "system_cpu_usage * 100", "legendFormat": "system CPU" }
      ]
    },
    {
      "title": "Non-Heap Memory Used (MB)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 24 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": { "defaults": { "unit": "decmbytes" }, "overrides": [] },
      "targets": [
        { "expr": "jvm_memory_used_bytes{area=\"nonheap\"} / 1024 / 1024", "legendFormat": "{{id}}" }
      ]
    },
    {
      "title": "Code Cache (MB)",
      "description": "JIT 컴파일된 네이티브 코드 저장소. 다 차면 JIT가 멈춤.",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 24 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": { "defaults": { "unit": "decmbytes" }, "overrides": [] },
      "targets": [
        { "expr": "jvm_memory_used_bytes{id=~\"CodeHeap.*\"} / 1024 / 1024", "legendFormat": "used ({{id}})" },
        { "expr": "jvm_memory_max_bytes{id=~\"CodeHeap.*\"} / 1024 / 1024", "legendFormat": "max ({{id}})" }
      ]
    },
    {
      "title": "Tomcat Threads",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 32 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        { "expr": "tomcat_threads_current_threads{application=\"jvm-pool-lab\"}", "legendFormat": "current" },
        { "expr": "tomcat_threads_busy_threads{application=\"jvm-pool-lab\"}", "legendFormat": "busy" },
        { "expr": "tomcat_threads_config_max_threads{application=\"jvm-pool-lab\"}", "legendFormat": "max (config)" }
      ]
    },
    {
      "title": "JVM Threads",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 32 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        { "expr": "jvm_threads_live_threads", "legendFormat": "live" },
        { "expr": "jvm_threads_peak_threads", "legendFormat": "peak" },
        { "expr": "jvm_threads_daemon_threads", "legendFormat": "daemon" }
      ]
    },
    {
      "title": "HikariCP Connections",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 40 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        { "expr": "hikaricp_connections_active", "legendFormat": "active" },
        { "expr": "hikaricp_connections_idle", "legendFormat": "idle" },
        { "expr": "hikaricp_connections", "legendFormat": "total" },
        { "expr": "hikaricp_connections_pending", "legendFormat": "pending (waiting)" }
      ]
    },
    {
      "title": "Direct Buffer Memory (bytes)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 40 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        { "expr": "jvm_buffer_memory_used_bytes{id=\"direct\"}", "legendFormat": "used" },
        { "expr": "jvm_buffer_total_capacity_bytes{id=\"direct\"}", "legendFormat": "capacity" }
      ]
    },
    {
      "title": "HTTP Request Rate (per sec)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 48 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        { "expr": "rate(http_server_requests_seconds_count[30s])", "legendFormat": "{{method}} {{uri}} {{status}}" }
      ]
    },
    {
      "title": "HTTP Response Time (ms, avg)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 48 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": { "defaults": { "unit": "ms" }, "overrides": [] },
      "targets": [
        { "expr": "rate(http_server_requests_seconds_sum[30s]) / rate(http_server_requests_seconds_count[30s]) * 1000", "legendFormat": "{{method}} {{uri}}" }
      ]
    }
  ],
  "refresh": "5s",
  "schemaVersion": 39,
  "tags": ["jvm", "gc", "lab"],
  "templating": {
    "list": [
      {
        "current": { "selected": false, "text": "Prometheus", "value": "Prometheus" },
        "hide": 0,
        "includeAll": false,
        "name": "DS_PROMETHEUS",
        "options": [],
        "query": "prometheus",
        "type": "datasource"
      }
    ]
  },
  "time": { "from": "now-15m", "to": "now" },
  "title": "JVM Pool Lab",
  "uid": "jvm-pool-lab",
  "version": 1
}
